  .clk_100mhz_clk_n(clk_100mhz_clk_n), // input wire clk_100mhz_clk_n
  .clk_100mhz_clk_p(clk_100mhz_clk_p), // input wire clk_100mhz_clk_p
  .PL_USER_PB_0(PL_USER_PB_0), // input wire PL_USER_PB_0
  .ROT_A(ROT_A), // input wire ROT_A
  .ROT_B(ROT_B), // input wire ROT_B
